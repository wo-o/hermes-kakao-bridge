# Copy to bridge.env (chmod 600) and fill in. NEVER commit bridge.env.
# Absolute path to the hermes CLI — set to `command -v hermes` output.
# HERMES_BIN=/home/ubuntu/.local/bin/hermes
# Seconds to wait for hermes; MUST stay under Kakao's ~60s callbackUrl expiry
HERMES_TIMEOUT=50
# 0 = stateless one-shot (default; every message uses the latest SOUL/skills), 1 = per-user multi-turn session (--continue kakao-<userId>)
KAKAO_PER_USER_SESSION=0
# Dedicated hermes profile for Kakao (isolated SOUL/memory/sessions) — created by setup.sh.
# Remove this line to answer as the main agent (~/.hermes) instead.
HERMES_HOME=/home/ubuntu/.hermes/profiles/kakao
# Optional shared secret; if set, requests must carry header X-Bridge-Secret: <value>
# Generate with: openssl rand -hex 32
KAKAO_BRIDGE_SECRET=
# Optional: extra hermes CLI args, e.g. restrict tools (safe = web/vision/image_gen, no terminal)
# HERMES_EXTRA_ARGS=--toolsets safe
